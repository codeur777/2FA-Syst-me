# ============================================================
#  .gitignore GLOBAL — Monorepo 2FA Systeme
#  Backend: Spring Boot (Java/Maven)
#  Frontend Web: React + Vite (Node.js)
#  Frontend Mobile: Flutter/Dart
# ============================================================

# ─────────────────────────────────────────
# Environnements virtuels Python (si scripts utilitaires)
# ─────────────────────────────────────────
venv/
env/
.env
.venv/
ENV/
env.bak/
venv.bak/
__pycache__/
*.py[cod]

# ─────────────────────────────────────────
# Variables d'environnement & secrets
# ─────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
*.secret
secrets.properties
application-local.properties
application-prod.properties

# ─────────────────────────────────────────
# BACKEND — Java / Maven / Spring Boot
# ─────────────────────────────────────────
BACKEND/**/target/
BACKEND/**/*.class
BACKEND/**/*.jar
BACKEND/**/*.war
BACKEND/**/*.ear
BACKEND/**/*.log
BACKEND/**/.mvn/wrapper/maven-wrapper.jar
BACKEND/**/hs_err_pid*
BACKEND/**/.classpath
BACKEND/**/.project
BACKEND/**/.settings/
BACKEND/**/.factorypath

# ─────────────────────────────────────────
# FRONTEND WEB — Node.js / React / Vite
# ─────────────────────────────────────────
FRONTEND_WEB/**/node_modules/
FRONTEND_WEB/**/dist/
FRONTEND_WEB/**/build/
FRONTEND_WEB/**/.vite/
FRONTEND_WEB/**/.vite-temp/
FRONTEND_WEB/**/coverage/
FRONTEND_WEB/**/*.local
# Garder package-lock.json mais ignorer le lock à la racine si dupliqué
/FRONTEND_WEB/package-lock.json

# ─────────────────────────────────────────
# FRONTEND MOBILE — Flutter / Dart
# ─────────────────────────────────────────
FRONTEND_MOBILE/**/.dart_tool/
FRONTEND_MOBILE/**/build/
FRONTEND_MOBILE/**/.flutter-plugins
FRONTEND_MOBILE/**/.flutter-plugins-dependencies
FRONTEND_MOBILE/**/*.g.dart
FRONTEND_MOBILE/**/*.freezed.dart
FRONTEND_MOBILE/**/pubspec.lock
# Android
FRONTEND_MOBILE/**/android/local.properties
FRONTEND_MOBILE/**/android/.gradle/
FRONTEND_MOBILE/**/android/app/debug/
FRONTEND_MOBILE/**/android/app/profile/
FRONTEND_MOBILE/**/android/app/release/
FRONTEND_MOBILE/**/android/key.properties
FRONTEND_MOBILE/**/*.keystore
FRONTEND_MOBILE/**/*.jks
# iOS
FRONTEND_MOBILE/**/ios/Pods/
FRONTEND_MOBILE/**/ios/.symlinks/
FRONTEND_MOBILE/**/ios/Flutter/Flutter.framework
FRONTEND_MOBILE/**/ios/Flutter/Flutter.podspec
FRONTEND_MOBILE/**/ios/Flutter/Generated.xcconfig
FRONTEND_MOBILE/**/ios/Flutter/ephemeral/
FRONTEND_MOBILE/**/ios/Runner/GeneratedPluginRegistrant.*
# macOS
FRONTEND_MOBILE/**/macos/Flutter/GeneratedPluginRegistrant.swift
FRONTEND_MOBILE/**/macos/Flutter/ephemeral/

# ─────────────────────────────────────────
# IDEs & Éditeurs
# ─────────────────────────────────────────
# IntelliJ / Android Studio
.idea/
*.iml
*.iws
*.ipr
out/
# VS Code
.vscode/
# Eclipse
.classpath
.project
.settings/
# NetBeans
nbproject/
# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# ─────────────────────────────────────────
# Systèmes d'exploitation
# ─────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
# Linux
*~

# ─────────────────────────────────────────
# Logs & fichiers temporaires
# ─────────────────────────────────────────
*.log
*.tmp
*.temp
*.cache
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
